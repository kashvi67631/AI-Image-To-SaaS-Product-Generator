# =============================================================================
# LuxeGen monorepo — copy to `frontend/.env.local` and/or `gemini-image-to-react-backend/.env`
# Never commit real secrets. Gemini keys stay on the backend only.
# =============================================================================

# --- Next.js frontend (frontend/.env.local) ---------------------------------
# Origin of the Express API (prompt stream + image). Local default:
BACKEND_URL=http://127.0.0.1:8080

# Optional: same as BACKEND_URL but for server-side-only resolution (Docker/K8s):
# INTERNAL_BACKEND_URL=http://gemini-image-to-react-backend:8080

# Optional alias read by resolveProxyBackendBaseUrlMetadata:
# LUXEGEN_BACKEND_URL=http://127.0.0.1:8080

# Optional: if the browser must call a public API URL (rare for this app):
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# --- Express backend (gemini-image-to-react-backend/.env) ------------------
# Required for /api/generate and /api/image-to-react:
# GEMINI_API_KEY=

# Optional model override (defaults in server if unset):
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL_NAME=

# PORT=8080
# LISTEN_HOST=0.0.0.0

# Production CORS: comma-separated origins (see server.ts). Also set one of:
# PRODUCTION_FRONTEND_URL=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# VERCEL_PRODUCTION_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.example.com

# --- Vercel / deploy ---------------------------------------------------------
# This repo opens Vercel’s public “clone” deploy flow in the browser; no Vercel
# API token is required in env for that. Use VERCEL_PRODUCTION_URL (backend) so
# production CORS allows your deployed Next.js origin.
