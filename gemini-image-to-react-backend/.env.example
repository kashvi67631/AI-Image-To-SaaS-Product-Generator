# Copy to `.env` in this folder. Do not commit `.env`.

# Required for prompt streaming and image → React:
GEMINI_API_KEY=

# Optional (defaults shown in src/server.ts):
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL_NAME=

# PORT=8080
# LISTEN_HOST=0.0.0.0
# NODE_ENV=production

# CORS: production allowlist — comma-separated origins, no trailing slashes:
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Your deployed Next.js origin (used to extend CORS allowlist):
# PRODUCTION_FRONTEND_URL=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# VERCEL_PRODUCTION_URL=https://your-app.vercel.app
