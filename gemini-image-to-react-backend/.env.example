# Required for /api/image-to-react and /api/generate (Gemini never goes in the Next.js frontend .env).
GEMINI_API_KEY=
# Optional (fallback default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
# Optional alias supported by code as fallback.
GEMINI_MODEL_NAME=gemini-1.5-flash
# Listen port — server.ts uses app.listen(PORT, "0.0.0.0").
PORT=8080
# Frontend: BACKEND_URL=http://127.0.0.1:8080 (or http://localhost:8080 when bound on 0.0.0.0)
# Optional extra origins (comma-separated). Code always allows localhost/127.0.0.1 on 3000–3002.
ALLOWED_ORIGINS=
# Production frontend (Vercel). Also set NEXT_PUBLIC_API_URL on Vercel to your deployed backend URL.
PRODUCTION_FRONTEND_URL=https://your-app.vercel.app
