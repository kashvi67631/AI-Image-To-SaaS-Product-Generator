# Public: image-to-code backend (Express) when using screenshot upload.
# Local dev example:
# NEXT_PUBLIC_API_URL=http://localhost:3000/api/image-to-react
# Vercel example:
# NEXT_PUBLIC_API_URL=https://<your-backend-domain>/api/image-to-react
NEXT_PUBLIC_API_URL=

# Server-only: Next.js app/api/generate (Gemini streaming).
# Copy this file to .env.local and set GEMINI_API_KEY (no quotes; paste key right after =).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Optional alias supported by code as fallback.
GEMINI_MODEL_NAME=gemini-1.5-flash
